# Firebase Cloud Functions environment variables.
#
# Copy this file to `functions/.env` (gitignored) and fill in real values, then
# `firebase deploy --only functions`. These are set as PLAIN env vars on the
# Cloud Run services — do NOT also bind them as Secret Manager secrets in the
# function decorators (Cloud Run rejects a name that is both plain + secret).
#
# Deploy prerequisite: a local venv so firebase-tools can analyze the source:
#   python3.13 -m venv venv && venv/bin/pip install -r requirements.txt

# Google Gemini API key (analysis, vision, embeddings). Get one at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Twilio (WhatsApp capture + reminder replies). Required only for the
# whatsapp_webhook / process_link_background functions.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional overrides (sensible defaults exist in code).
# APP_URL=https://secondbrain-app-94da2.web.app
# CORS_ORIGIN=*
