# Firebase Cloud Functions environment variables.
#
# Copy this file to `functions/.env` (gitignored) and fill in real values, then
# `firebase deploy --only functions`. These are set as PLAIN env vars on the
# Cloud Run services — do NOT also bind them as Secret Manager secrets in the
# function decorators (Cloud Run rejects a name that is both plain + secret).
#
# Deploy prerequisite: a local venv so firebase-tools can analyze the source:
#   python3.13 -m venv venv && venv/bin/pip install -r requirements.txt

# Google Gemini API key (analysis, vision, embeddings). Get one at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Twilio (WhatsApp capture + reminder replies). Required only for the
# whatsapp_webhook / process_link_background functions.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Curated Digest email delivery ────────────────────────────────────────
# The digest feature sends curated cards by email and/or WhatsApp. WhatsApp
# reuses the Twilio config above. For email, configure EITHER SendGrid OR SMTP.
# If neither is set, email delivery degrades to a logged no-op (WhatsApp still
# works). The "From" address must be a verified sender with your provider.
#
# Option A — SendGrid (recommended; uses the HTTPS API, no extra dependency):
# SENDGRID_API_KEY=
#
# Option B — generic SMTP (e.g. Gmail app password, Mailgun, Postmark):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
#
# Sender shown on digest emails (used by both providers):
# DIGEST_FROM_EMAIL=Second Brain <digest@yourdomain.com>

# Optional overrides (sensible defaults exist in code).
# APP_URL=https://secondbrain-app-94da2.web.app
#
# CORS_ORIGIN: comma-separated allowlist of origins permitted to call the
# HTTP endpoints. Leave unset to default to the app's own Firebase Hosting +
# firebaseapp.com origins. Add the Vercel desktop domain here in production,
# e.g. CORS_ORIGIN=https://secondbrain-app-94da2.web.app,https://your-app.vercel.app
# Use "*" only for local debugging — never in production.
# CORS_ORIGIN=

# App Check enforcement. When truthy ("1"/"true"), the paid endpoints reject
# requests lacking a valid X-Firebase-AppCheck token (401). Leave unset/false
# for a soft rollout (verification is attempted and logged, but not enforced).
# APPCHECK_ENFORCE=

# ── Multi-user auth rollout (see NATIVE_AUTH_SETUP.md) ────────────────────────
# REQUIRE_AUTH: when truthy, every data endpoint/callable REQUIRES a valid
# Firebase ID token and derives the workspace uid from it (client-supplied uids
# are rejected). Leave OFF until sign-in is confirmed working end-to-end; flip to
# true at cutover together with NEXT_PUBLIC_REQUIRE_AUTH on the web build.
# REQUIRE_AUTH=

# OWNER_EMAIL: if set, only this account may claim the existing (single-owner)
# workspace via claim_workspace during the migration. Set it to your sign-in email.
# OWNER_EMAIL=

# ADMIN_TOKEN: shared secret required (as X-Admin-Token) to reach the debug/admin
# endpoints (debug_status, backfill_*, force_*). Unset → those endpoints 404.
# ADMIN_TOKEN=
