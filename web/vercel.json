{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.google.com https://www.gstatic.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.cloudfunctions.net https://*.web.app https://*.firebaseapp.com https://*.vercel.app https://www.google.com; frame-src https://www.google.com https://*.firebaseapp.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/analyze",
      "destination": "https://secondbrain-app-94da2.web.app/api/analyze"
    },
    {
      "source": "/api/analyze-image",
      "destination": "https://secondbrain-app-94da2.web.app/api/analyze-image"
    },
    {
      "source": "/api/share",
      "destination": "https://secondbrain-app-94da2.web.app/api/share"
    },
    {
      "source": "/api/article",
      "destination": "https://secondbrain-app-94da2.web.app/api/article"
    },
    {
      "source": "/api/claim-workspace",
      "destination": "https://secondbrain-app-94da2.web.app/api/claim-workspace"
    },
    {
      "source": "/api/search",
      "destination": "https://secondbrain-app-94da2.web.app/api/search"
    },
    {
      "source": "/api/delete-account",
      "destination": "https://secondbrain-app-94da2.web.app/api/delete-account"
    },
    {
      "source": "/api/publish-share",
      "destination": "https://secondbrain-app-94da2.web.app/api/publish-share"
    },
    {
      "source": "/api/unpublish-share",
      "destination": "https://secondbrain-app-94da2.web.app/api/unpublish-share"
    }
  ]
}
