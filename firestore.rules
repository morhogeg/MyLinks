rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can access their own document.
    //
    // SECURITY — ACCEPTED RESIDUAL RISK (auth rollout in progress):
    // Phase 1 (web Google Sign-In) is LIVE, but these rules stay open on purpose.
    // The data doc is keyed by phone number, NOT the Auth uid, and the native iOS
    // shell + share ingest + WhatsApp paths still write without a user token.
    // Locking now would brick them. Cloud Functions are hardened (App Check +
    // pinned CORS + rate limiting), so the realistic abuse surface is reduced.
    //
    // PHASE 3 LOCK (apply once native sign-in + backend token verification land —
    // see AUTH_SPEC.md). Ownership is membership in the doc's `authUids` array,
    // because the doc ID is the phone number, not request.auth.uid:
    //
    //   function owns(uid) {
    //     return request.auth != null
    //       && get(/databases/$(database)/documents/users/$(uid))
    //            .data.authUids.hasAny([request.auth.uid]);
    //   }
    //   match /users/{uid}             { allow read, write: if owns(uid);
    //     match /links/{linkId}        { allow read, write: if owns(uid); }
    //     match /chats/{chatId}        { allow read, write: if owns(uid); }
    //     match /collections/{cid}     { allow read, write: if owns(uid); }
    //   }
    match /users/{uid} {
      allow read, write: if true;

      match /links/{linkId} {
        allow read, write: if true;
      }

      // Ask-your-brain saved conversations
      match /chats/{chatId} {
        allow read, write: if true;
      }

      // User-curated collections of cards
      match /collections/{collectionId} {
        allow read, write: if true;
      }
    }

    // Shared collections & cards: public, read-only snapshots for share links.
    // World-readable so logged-out visitors can open /c?id= and /s?id= pages.
    // Writes are owner-driven from the client today (single-user prototype, same
    // residual risk as users/** above); tighten to `request.auth.uid == ownerUid`
    // when real Firebase Auth lands.
    match /shared_collections/{shareId} {
      allow read: if true;
      allow write: if true;
    }
    match /shared_cards/{shareId} {
      allow read: if true;
      allow write: if true;
    }

    // pending_processing: only Cloud Functions (admin SDK)
    match /pending_processing/{docId} {
      allow read, write: if false;
    }

    // task_logs: only Cloud Functions (admin SDK)
    match /task_logs/{docId} {
      allow read, write: if false;
    }
  }
}
