{
  "manifest_version": 3,
  "name": "MyLinks — Save to Second Brain",
  "description": "One-click capture of any page, link, or selection into your MyLinks second brain.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Save to MyLinks (click to save this page)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": ["https://secondbrain-app-94da2.web.app/*"],
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save the current tab to MyLinks"
    }
  }
}
