{
  "name": "machina-firestore-rules-test",
  "version": "1.0.0",
  "private": true,
  "description": "Emulator tests for the locked Firestore ruleset (firestore.rules.locked) — run before the auth-cutover rules deploy.",
  "type": "module",
  "scripts": {
    "pretest": "node -e \"require('fs').copyFileSync('../firestore.rules.locked','./firestore.rules.locked.copy')\"",
    "test": "firebase emulators:exec --only firestore --project demo-machina-rules \"node --test rules.test.mjs\"",
    "test:against-running-emulator": "node --test rules.test.mjs"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "firebase": "^12.0.0",
    "firebase-tools": "^14.0.0"
  }
}
